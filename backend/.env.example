# SnapStyle AI Backend Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://username:password@localhost:5432/snapstyle

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
# Generate a secure secret key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-256-bit-secret-key-here
ALGORITHM=HS256
# Token expiration in minutes (default: 7 days = 10080 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# =============================================================================
# GOOGLE GEMINI AI
# =============================================================================
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key

# =============================================================================
# SERPAPI (Product Search - $50/month for 5,000 searches)
# =============================================================================
# Get your API key from: https://serpapi.com/
SERPAPI_API_KEY=your-serpapi-api-key

# =============================================================================
# GOOGLE CUSTOM SEARCH API (Cheaper alternative - $5 per 1,000 searches)
# =============================================================================
# Much cheaper than SerpAPI! 100 free searches/day
# 1. Get API key: https://console.cloud.google.com/apis/credentials
# 2. Enable "Custom Search API" in your project
# 3. Create search engine: https://programmablesearchengine.google.com/
# 4. Configure it to search shopping sites
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# =============================================================================
# STRIPE PAYMENT PROCESSING
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Webhook secret from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Create these prices in Stripe Dashboard
STRIPE_PRICE_BASIC=price_your-basic-price-id
STRIPE_PRICE_PRO=price_your-pro-price-id
STRIPE_PRICE_UNLIMITED=price_your-unlimited-price-id

# Deep link URLs for payment callbacks
STRIPE_SUCCESS_URL=snapstyleai://payment-success
STRIPE_CANCEL_URL=snapstyleai://payment-cancel

# =============================================================================
# APPLE SIGN-IN (Required for production)
# =============================================================================
# Your app's bundle identifier
APPLE_BUNDLE_ID=com.yourcompany.snapstyleai
APPLE_SHARED_SECRET=your-apple-shared-secret

# =============================================================================
# AWS S3 (Optional - for production image storage)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# =============================================================================
# GOOGLE SHOPPING API (Optional)
# =============================================================================
GOOGLE_SHOPPING_API_KEY=

# =============================================================================
# AFFILIATE NETWORKS (Revenue from product links)
# =============================================================================
# Amazon Associates - Direct Amazon affiliate
AMAZON_ASSOCIATE_TAG=
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=

# Skimlinks - Universal affiliate (48,000+ merchants)
# Sign up FREE at: https://skimlinks.com
# This is the RECOMMENDED option - works with ALL retailers automatically
SKIMLINKS_PUBLISHER_ID=

# Sovrn Commerce - Alternative to Skimlinks
# Sign up FREE at: https://commerce.sovrn.com
SOVRN_PUBLISHER_ID=

# =============================================================================
# REDIS CACHING (Reduces API costs by 40-60%)
# =============================================================================
# Redis provides fast, shared caching across server instances
# Railway provides free Redis: https://railway.app (add Redis service)
# Leave empty to use file-based caching (works fine for single instance)
REDIS_URL=

# Cache TTL in seconds (default: 86400 = 24 hours)
SEARCH_CACHE_TTL_SECONDS=86400

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode - MUST be false in production
# Enables: API docs, debug logging, dev endpoints
DEBUG=false

# CORS origins (comma-separated for multiple)
CORS_ORIGINS=["https://snapstyle.ai"]

# Base URL for API (used for image URLs)
BASE_URL=https://api.snapstyle.ai

# =============================================================================
# CLOUDINARY (Image hosting for Google Lens)
# =============================================================================
# Sign up FREE at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# =============================================================================
# USAGE LIMITS
# =============================================================================
FREE_TIER_DAILY_SEARCHES=5

# =============================================================================
# ADMIN ACCESS
# =============================================================================
# Secret key for admin operations (grant unlimited, etc.)
ADMIN_SECRET_KEY=
